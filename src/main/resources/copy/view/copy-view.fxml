<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.effect.BoxBlur?>
<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.text.Text?>
<?import java.net.URL?>

<StackPane fx:id="rootPane"
           styleClass="root-pane"
           prefWidth="660"
           prefHeight="430"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="copy.controller.CopyController">

    <stylesheets>
        <URL value="@../css/style.css"/>
    </stylesheets>

    <Pane fx:id="backgroundGlowPane" styleClass="background-glow-pane" mouseTransparent="true">
        <Circle fx:id="glowTopRight" radius="100" layoutX="580" layoutY="80" styleClass="glow-spot, glow-blue">
            <effect>
                <BoxBlur width="120" height="120" iterations="3"/>
            </effect>
        </Circle>
        <Circle fx:id="glowBottomLeft" radius="90" layoutX="100" layoutY="350" styleClass="glow-spot, glow-green">
            <effect>
                <BoxBlur width="110" height="110" iterations="3"/>
            </effect>
        </Circle>
        <Circle fx:id="glowBottomRight" radius="80" layoutX="560" layoutY="360" styleClass="glow-spot, glow-purple">
            <effect>
                <BoxBlur width="100" height="100" iterations="3"/>
            </effect>
        </Circle>
    </Pane>

    <VBox spacing="0" alignment="TOP_CENTER">
        
        <HBox fx:id="titleBar" styleClass="title-bar" alignment="CENTER_LEFT" prefHeight="35">
            <padding>
                <Insets left="15" right="10"/>
            </padding>
            
            <Label text="Copiador de Diretórios" styleClass="window-title"/>
            
            <Pane HBox.hgrow="ALWAYS" />
            
            <HBox spacing="6" alignment="CENTER">
                <Button fx:id="themeBtn" onAction="#onToggleTheme" styleClass="window-control-btn, theme-toggle-btn" text="☀"/>
                <Button onAction="#onMinimize" styleClass="window-control-btn, minimize-btn" text="—"/>
                <Button onAction="#onMaximizeDummy" styleClass="window-control-btn, maximize-btn" text="⬜"/>
                <Button onAction="#onClose" styleClass="window-control-btn, close-btn" text="✕"/>
            </HBox>
        </HBox>

        <VBox spacing="20" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="15" right="35" bottom="25" left="35"/>
            </padding>

            <VBox spacing="6" alignment="CENTER" styleClass="header-box">
                <Label text="Copiador de Diretórios" styleClass="title-label"/>
                <TextFlow styleClass="subtitle-flow" textAlignment="CENTER">
                    <Text text="Selecione os diretórios de origem e destino para realizar a cópia de forma rápida e " styleClass="subtitle-text"/>
                    <Text text="moderna." styleClass="subtitle-text, subtitle-bold"/>
                </TextFlow>
            </VBox>

            <HBox spacing="20" alignment="CENTER" fillHeight="true">
                
                <VBox alignment="CENTER" styleClass="card, left-card" prefWidth="150" prefHeight="150">
                    <StackPane styleClass="folder-icon-container">
                        <Region styleClass="folder-back"/>
                        <Region styleClass="folder-front"/>
                    </StackPane>
                </VBox>
                
                <VBox alignment="CENTER" styleClass="card, right-card" spacing="12" HBox.hgrow="ALWAYS" prefHeight="150">
                    <padding>
                        <Insets top="18" right="18" bottom="18" left="18"/>
                    </padding>
                    
                    <HBox fx:id="sourceWrapper" styleClass="input-wrapper" alignment="CENTER_LEFT" onMouseClicked="#onBrowseSource">
                        <TextField fx:id="sourceField"
                                   promptText="Selecionar pasta de origem..."
                                   styleClass="custom-text-field"
                                   HBox.hgrow="ALWAYS"
                                   editable="false"
                                   onMouseClicked="#onBrowseSource"/>
                        <Label text="&gt;" styleClass="input-chevron"/>
                    </HBox>
                    
                    <HBox fx:id="destWrapper" styleClass="input-wrapper" alignment="CENTER_LEFT" onMouseClicked="#onBrowseDest">
                        <TextField fx:id="destField"
                                   promptText="Selecionar pasta de destino..."
                                   styleClass="custom-text-field"
                                   HBox.hgrow="ALWAYS"
                                   editable="false"
                                   onMouseClicked="#onBrowseDest"/>
                        <Label text="&gt;" styleClass="input-chevron"/>
                    </HBox>
                </VBox>
            </HBox>

            <VBox spacing="12" alignment="CENTER" VBox.vgrow="ALWAYS">
                <Button fx:id="copyButton"
                        text="→   Iniciar Cópia"
                        styleClass="action-button"
                        onAction="#onStartCopy"
                        maxWidth="220"/>

                <ProgressBar fx:id="progressBar"
                             progress="-1"
                             maxWidth="220"
                             visible="false"
                             managed="false"/>

                <Label fx:id="statusLabel"
                       text=""
                       styleClass="status-label"
                       wrapText="true"
                       alignment="CENTER"
                       textAlignment="CENTER"/>
            </VBox>
        </VBox>
    </VBox>
</StackPane>
